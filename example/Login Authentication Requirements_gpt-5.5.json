      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Start",
      "fill_color": "#e0e0e0"
    },
    {
      "id": 2,
      "type": "io",
      "x": 510,
      "y": 217,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Input Username and Password",
      "fill_color": "#FFFFFF",
      "details": "・Collect username or account ID\n・Collect password securely over TLS\n・Do not log raw credentials",
      "note": {
        "dx": -315,
        "dy": -90,
        "display_state": "normal"
      }
    },
    {
      "id": 3,
      "type": "decision",
      "x": 510,
      "y": 277,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Account Locked?",
      "fill_color": "#FFFFFF",
      "details": "・Check account lock status by username or account ID\n・Use a lock_until timestamp or equivalent\n・Avoid messages that reveal whether the account exists",
      "note": {
        "dx": 285,
        "dy": -165,
        "display_state": "normal"
      }
    },
    {
      "id": 4,
      "type": "decision",
      "x": 345,
      "y": 277,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Lock Period Expired?",
      "fill_color": "#FFFFFF"
    },
    {
      "id": 5,
      "type": "process",
      "x": 345,
      "y": 337,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Release Account Lock",
      "fill_color": "#FFFFFF",
      "details": "・Clear lock status when the configured lock period has expired\n・Reset or retain failed-attempt history according to security policy",
      "note": {
        "dx": -240,
        "dy": -30,
        "display_state": "normal"
      }
    },
    {
      "id": 6,
      "type": "decision",
      "x": 510,
      "y": 337,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Password\n Format Valid?",
      "fill_color": "#FFFFFF",
      "details": "・Password length must be 8 to 16 characters\n・Password must include letters, numbers, and special characters\n・Validate on the server side",
      "note": {
        "dx": 480,
        "dy": -120,
        "display_state": "normal"
      }
    },
    {
      "id": 7,
      "type": "process",
      "x": 510,
      "y": 397,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Verify Username and Password",
      "fill_color": "#FFFFFF",
      "details": "・Compare password using a secure password hash\n・Use constant-time comparison where applicable\n・Return a generic authentication result",
      "note": {
        "dx": 480,
        "dy": -30,
        "display_state": "normal"
      }
    },
    {
      "id": 8,
      "type": "decision",
      "x": 510,
      "y": 457,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Credentials\n Valid?",
      "fill_color": "#FFFFFF"
    },
    {
      "id": 9,
      "type": "process",
      "x": 510,
      "y": 517,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Initiate 2FA Challenge",
      "fill_color": "#FFFFFF",
      "details": "・2FA is mandatory after valid password verification\n・Supported factors must be defined, such as TOTP, authenticator app, SMS, email, or hardware key\n・Set challenge expiration time and retry limits",
      "note": {
        "dx": -405,
        "dy": -30,
        "display_state": "normal"
      }
    },
    {
      "id": 10,
      "type": "io",
      "x": 510,
      "y": 577,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Input 2FA Code",
      "fill_color": "#FFFFFF"
    },
    {
      "id": 11,
      "type": "decision",
      "x": 510,
      "y": 637,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "2FA Valid?",
      "fill_color": "#FFFFFF"
    },
    {
      "id": 12,
      "type": "process",
      "x": 690,
      "y": 637,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Increment Failed Attempt Count",
      "fill_color": "#FFFFFF",
      "details": "・Count failed password-format, credential, and 2FA attempts as authentication failures\n・Store failed-attempt count per account\n・Consider rate limiting by IP/device as an additional control",
      "note": {
        "dx": 300,
        "dy": -120,
        "display_state": "normal"
      }
    },
    {
      "id": 13,
      "type": "decision",
      "x": 690,
      "y": 697,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Failed Attempts\n >= 5?",
      "fill_color": "#FFFFFF"
    },
    {
      "id": 14,
      "type": "process",
      "x": 840,
      "y": 697,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Lock Account",
      "fill_color": "#FFFFFF",
      "details": "・Lock account after five or more failed authentication attempts\n・Lock duration must be specified as a configurable security parameter\n・Record lock start time, lock_until time, and audit event",
      "note": {
        "dx": 150,
        "dy": -30,
        "display_state": "normal"
      }
    },
    {
      "id": 15,
      "type": "io",
      "x": 690,
      "y": 757,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Notify Authentication Failure",
      "fill_color": "#FFFFFF",
      "details": "・Display a generic failure message\n・If locked, notify that access is temporarily unavailable\n・Avoid exposing whether username, password, or 2FA failed",
      "note": {
        "dx": 300,
        "dy": 60,
        "display_state": "normal"
      }
    },
    {
      "id": 16,
      "type": "process",
      "x": 510,
      "y": 697,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Reset Failed Attempts and Create Session",
      "fill_color": "#FFFFFF",
      "details": "・Reset failed-attempt count after successful password and 2FA verification\n・Create secure authenticated session\n・Set session timeout and secure cookie attributes",
      "note": {
        "dx": -405,
        "dy": -30,
        "display_state": "normal"
      }
    },
    {
      "id": 17,
      "type": "io",
      "x": 510,
      "y": 757,
      "w": 120,
      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Login Success",
      "fill_color": "#FFFFFF"
    },
    {
