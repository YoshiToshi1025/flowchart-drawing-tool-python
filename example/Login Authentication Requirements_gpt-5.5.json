      "h": 45,
      "shape_type": "corner_rounded_rectangle",
      "text": "Notify Account Locked",
      "fill_color": "#FFFFFF",
      "details": "・Inform user that login is temporarily unavailable\n・Do not disclose sensitive account state beyond necessary lockout guidance",
      "note": {
        "dx": -165,
